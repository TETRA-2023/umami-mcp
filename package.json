{
  "name": "@tetra-2023/umami-mcp",
  "version": "0.1.4",
  "description": "MCP server for Umami Analytics with stdio + streamable-http transports and an optional bearer-token middleware for gateway deployment",
  "type": "module",
  "bin": {
    "umami-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "umami",
    "analytics",
    "model-context-protocol"
  ],
  "author": "TETRA",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TETRA-2023/umami-mcp.git"
  },
  "homepage": "https://github.com/TETRA-2023/umami-mcp",
  "bugs": {
    "url": "https://github.com/TETRA-2023/umami-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.21.2",
    "zod": "^3.24.2"
  },
  "overrides": {
    "hono": ">=4.12.14",
    "@hono/node-server": ">=1.19.13",
    "express-rate-limit": ">=8.2.2",
    "esbuild": ">=0.25.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.16.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.16.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.0",
    "semantic-release": "^24.2.9",
    "supertest": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
