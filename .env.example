# Umami instance URL (no trailing slash)
UMAMI_URL=http://localhost:3000

# Auth — pick one path:
#   1. API key (Umami Cloud or self-hosted with API keys enabled)
UMAMI_API_KEY=
#   2. Username + password (self-hosted, JWT login)
UMAMI_USERNAME=
UMAMI_PASSWORD=

# Transport mode: stdio (default) | streamable-http | sse
UMAMI_TRANSPORT=stdio

# Bind config — only meaningful under HTTP transports
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Optional: when set under HTTP transports (streamable-http / sse), every
# request must present 'Authorization: Bearer <token>'. No-op for stdio.
# MCP_BEARER_TOKEN=replace_with_a_random_secret
